# Core service configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rust_basic_api
DATABASE_MAX_CONNECTIONS=5
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
RUST_LOG=info

