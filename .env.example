# Database Configuration
# Set your PostgreSQL connection string here
# Format: postgresql://username:secret@host:port/database
DATABASE_URL=postgresql://user:secret@localhost:5432/dbname

# Server Configuration
# Port on which the HTTP server will listen
SERVER_PORT=3000

# Logging Configuration
# Logging level: trace, debug, info, warn, error
# Can specify per-module: info,rust_basic_api=debug,tower_http=debug
RUST_LOG=info
