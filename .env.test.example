# Test Environment Configuration
# Copy this file to .env.test and configure for your environment
# This file configures the environment for running tests

# Database connection for testing
# Uses a separate test database to avoid polluting development data
# Set your PostgreSQL test credentials here
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/rust_api_test

# Logging configuration for tests
# Set to 'debug' for detailed test output, 'info' for standard output
RUST_LOG=rust_basic_api=debug,sqlx=warn,tower_http=debug

# Server configuration (tests may override these)
SERVER_PORT=3001
