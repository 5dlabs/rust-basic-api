# Core service configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rust_basic_api
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Database pool tuning
DATABASE_POOL_MAX_CONNECTIONS=5
DATABASE_POOL_MIN_CONNECTIONS=1
DATABASE_POOL_ACQUIRE_TIMEOUT_SECONDS=10

# Observability
RUST_LOG=info
